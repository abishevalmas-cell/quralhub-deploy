{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/passgen/layout,_N_T_/passgen/page,_N_T_/passgen"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/passgen/__PAGE__",
    "/passgen",
    "/_index",
    "/_head"
  ]
}
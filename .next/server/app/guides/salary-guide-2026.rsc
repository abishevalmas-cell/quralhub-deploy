f:["$","$1","c",{"children":[[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"WebApplication\",\"name\":\"Жалақы есебі 2026 — толық нұсқаулық\",\"description\":\"Жалақыдан ұсталымдарды қалай есептеу керек: ОПВ, ИПН, ВОСМС. Қадамдық нұсқаулық мысалмен.\",\"url\":\"https://quralhub.kz/guides/salary-guide-2026\",\"applicationCategory\":\"FinanceApplication\",\"operatingSystem\":\"Any\",\"offers\":{\"@type\":\"Offer\",\"price\":\"0\",\"priceCurrency\":\"KZT\"},\"inLanguage\":[\"kk\",\"ru\"]}"}}],["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"FAQPage\",\"mainEntity\":[{\"@type\":\"Question\",\"name\":\"2026 жылы жалақыдан қандай ұсталымдар бар?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Қызметкерден: ОПВ 10%, ИПН 10-15%, ВОСМС 2%. Жұмыс берушіден: СО 5%, СН 6%, ООСМС 3%, ОПВР 3.5%.\"}},{\"@type\":\"Question\",\"name\":\"2026 жылы ИПН вычет қанша?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"30 МРП = 129 750₸. 2025 жылы 14 МРП = 48 300₸ болған. Бұл салық базасын айтарлықтай азайтады.\"}},{\"@type\":\"Question\",\"name\":\"Прогрессивті ИПН қалай жұмыс істейді?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Жылдық табыс 36 762 500₸ (8 500 МРП) дейін — 10%, одан жоғары бөлігі — 15%.\"}},{\"@type\":\"Question\",\"name\":\"350 000₸ жалақыдан қолға қанша шығады?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Шамамен 283 225₸. ОПВ 35 000₸, ИПН 18 525₸, ВОСМС 7 000₸ ұсталады.\"}},{\"@type\":\"Question\",\"name\":\"ОПВР деген не?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Жұмыс берушінің міндетті зейнетақы жарнасы. 2026 жылдан 3.5% (2025 жылы 1.5% болған).\"}}]}"}}],["$","$L12",null,{"title":"Жалақы есебі 2026 — толық нұсқаулық","subtitle":"Жаңа Салық кодексі бойынша жалақыдан ұсталымдарды қалай есептеу керек. 350 000₸ мысалмен қадамдық нұсқаулық.","date":"2026-01-15","readTime":"8 мин","tool":"Жалақы есебі нұсқаулық","children":[["$","p",null,{"children":"2026 жылдан бастап Қазақстанда жаңа Салық кодексі қолданысқа енді. Жалақы есептеу тәртібі бірнеше маңызды өзгерістерге ұшырады: ИПН вычет 14 МРП-дан 30 МРП-ға дейін өсті, ОПВР ставкасы 1.5%-дан 3.5%-ға көтерілді, прогрессивті ИПН шкаласы енгізілді."}],["$","h2",null,{"children":"Жалақыдан ұсталатын барлық төлемдер"}],["$","table",null,{"children":[["$","thead",null,{"children":["$","tr",null,{"children":[["$","th",null,{"children":"Ұсталым"}],["$","th",null,{"children":"Ставка"}],["$","th",null,{"children":"Кімнен"}],["$","th",null,{"children":"Ескерту"}]]}]}],["$","tbody",null,{"children":[["$","tr",null,{"children":[["$","td",null,{"children":"ОПВ (міндетті зейнетақы)"}],["$","td",null,{"children":"10%"}],["$","td",null,{"children":"Қызметкер"}],["$","td",null,{"children":"Максимум 50 МЗП = 4 250 000₸"}]]}],["$","tr",null,{"children":[["$","td",null,{"children":"ИПН (табыс салығы)"}],["$","td",null,{"children":"10-15%"}],["$","td",null,{"children":"Қызметкер"}],["$","td",null,{"children":"Прогрессивті шкала"}]]}],["$","tr",null,{"children":[["$","td",null,{"children":"ВОСМС (медициналық)"}],["$","td",null,{"children":"2%"}],["$","td",null,{"children":"Қызметкер"}],["$","td",null,{"children":"Табыстан"}]]}],["$","tr",null,{"children":[["$","td",null,{"children":"СО (әлеуметтік)"}],["$","td",null,{"children":"5%"}],["$","td",null,{"children":"Жұмыс беруші"}],["$","td",null,{"children":"Табыс минус ОПВ"}]]}],["$","tr",null,{"children":[["$","td",null,{"children":"СН (әлеуметтік салық)"}],["$","td",null,{"children":"6%"}],["$","td",null,{"children":"Жұмыс беруші"}],["$","td",null,{"children":"Минус СО"}]]}],["$","tr",null,{"children":[["$","td",null,{"children":"ООСМС"}],["$","td",null,{"children":"3%"}],["$","td",null,{"children":"Жұмыс беруші"}],["$","td",null,{"children":"Табыстан"}]]}],["$","tr",null,{"children":[["$","td",null,{"children":"ОПВР"}],["$","td",null,{"childr
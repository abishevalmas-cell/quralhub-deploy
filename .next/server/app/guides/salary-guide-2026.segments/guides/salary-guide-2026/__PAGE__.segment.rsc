0:{"buildId":"9gdLMajt7eqmHkJIwRBPh","rsc":["$","$1","c",{"children":[[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"WebApplication\",\"name\":\"Жалақы есебі 2026 — толық нұсқаулық\",\"description\":\"Жалақыдан ұсталымдарды қалай есептеу керек: ОПВ, ИПН, ВОСМС. Қадамдық нұсқаулық мысалмен.\",\"url\":\"https://quralhub.kz/guides/salary-guide-2026\",\"applicationCategory\":\"FinanceApplication\",\"operatingSystem\":\"Any\",\"offers\":{\"@type\":\"Offer\",\"price\":\"0\",\"priceCurrency\":\"KZT\"},\"inLanguage\":[\"kk\",\"ru\"]}"}}],["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"FAQPage\",\"mainEntity\":[{\"@type\":\"Question\",\"name\":\"2026 жылы жалақыдан қандай ұсталымдар бар?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Қызметкерден: ОПВ 10%, ИПН 10-15%, ВОСМС 2%. Жұмыс берушіден: СО 5%, СН 6%, ООСМС 3%, ОПВР 3.5%.\"}},{\"@type\":\"Question\",\"name\":\"2026 жылы ИПН вычет қанша?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"30 МРП = 129 750₸. 2025 жылы 14 МРП = 48 300₸ болған. Бұл салық базасын айтарлықтай азайтады.\"}},{\"@type\":\"Question\",\"name\":\"Прогрессивті ИПН қалай жұмыс істейді?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Жылдық табыс 36 762 500₸ (8 500 МРП) дейін — 10%, одан жоғары бөлігі — 15%.\"}},{\"@type\":\"Question\",\"name\":\"350 000₸ жалақыдан қолға қанша шығады?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Шамамен 283 225₸. ОПВ 35 000₸, ИПН 18 525₸, ВОСМС 7 000₸ ұсталады.\"}},{\"@type\":\"Question\",\"name\":\"ОПВР деген не?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Жұмыс берушінің міндетті зейнетақы жарнасы. 2026 жылдан 3.5% (2025 жылы 1.5% болған).\"}}]}"}}],["$","$L2",null,{"title":"Жалақы есебі 2026 — толық нұсқаулық","subtitle":"Жаңа Салық кодексі бойынша жалақыдан ұсталымдарды қалай есептеу керек. 350 000₸ мысалм
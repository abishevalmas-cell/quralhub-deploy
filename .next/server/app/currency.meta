{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/currency/layout,_N_T_/currency/page,_N_T_/currency"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/currency/__PAGE__",
    "/currency",
    "/_index",
    "/_head"
  ]
}
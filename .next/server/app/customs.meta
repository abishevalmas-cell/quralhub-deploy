{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/customs/layout,_N_T_/customs/page,_N_T_/customs"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/customs/__PAGE__",
    "/customs",
    "/_index",
    "/_head"
  ]
}